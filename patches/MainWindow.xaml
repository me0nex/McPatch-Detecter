<Window x:Class="patches.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:patches.ViewModels"
        mc:Ignorable="d"
        Title="patch detecter"
        Width="520"
        Height="520"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="#0A0B0D">
    <Border Margin="16"
            CornerRadius="18"
            Background="#101113"
            BorderBrush="#1F2328"
            BorderThickness="1"
            Padding="14">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <Button x:Name="ScanButton"
                        HorizontalAlignment="Center"
                        Width="96"
                        Content="scan"
                        Click="ScanButton_OnClick"
                        Style="{StaticResource AccentButtonStyle}" />
            </DockPanel>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="PatchItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PatchCardViewModel}">
                            <Border Margin="0,0,0,8"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="#0C0E12"
                                    BorderBrush="#1C2631"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}"
                                               Grid.Column="0"
                                               Foreground="#F1F6FC"
                                               FontSize="15" />
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               Text="{Binding StatusText}"
                                               Foreground="#25B4FF"
                                               FontSize="15" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="4"
                       x:Name="FooterStatusText"
                       Foreground="#75869A"
                       Text="Ready." />

            <TextBlock Grid.Row="6"
                       x:Name="HashTextBlock"
                       Foreground="#25B4FF"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Text="HASH: -" />
        </Grid>
    </Border>
</Window>
